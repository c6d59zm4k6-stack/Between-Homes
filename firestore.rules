rules_version = '2';

// MVP-level rules for a two-parent shared journey. A journey's `joinCode`
// is the shared secret that lets a second device find and join it — so
// journey documents are readable to any signed-in (including anonymous)
// user, which is what makes "join with a code" possible without a backend.
// Everything else (photos, prompts, voice notes, chapters) is locked to
// members of that specific journey. Review before opening this app up
// beyond trusted family use.

service cloud.firestore {
  match /databases/{database}/documents {

    match /journeys/{journeyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;

      // Members can update anything. A non-member may ONLY add themselves
      // to the members array (the "join" operation) — nothing else.
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.auth.uid in request.resource.data.members
        )
      );

      function isMember() {
        return request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/journeys/$(journeyId)).data.members;
      }

      match /milestones/{docId} {
        allow read, write: if isMember();
      }
      match /photos/{docId} {
        allow read, write: if isMember();
      }
      match /promptAnswers/{docId} {
        allow read, write: if isMember();
      }
      match /voiceNotes/{docId} {
        allow read, write: if isMember();
      }
      match /chapters/{docId} {
        allow read, write: if isMember();
      }
      match /subscriptions/{docId} {
        allow read, write: if isMember();
      }
    }
  }
}
